generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id String @id @default(uuid(4))

  name             String @unique
  tickets_amount   Int    @default(1)
  tickets_reserved Int    @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("events")
}
