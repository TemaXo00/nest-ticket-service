generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Ticket {
  id String @id @default(uuid(4))

  event_id String
  event    KnownEvents @relation(fields: [event_id], references: [id], onDelete: Cascade)

  user_id String

  @@map("tickets")
}

model KnownEvents {
  id String @id

  name String

  tickets Ticket[]

  created_at DateTime @default(now())

  @@map("known_events")
}
