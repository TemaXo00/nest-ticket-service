{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "all:serve": "nx run-many -t serve",
    "all:build": "nx run-many -t build",
    "all:preview": "nx run-many -t preview",

    "ticket-api:serve": "nx serve ticket-api",
    "ticket-api:build": "nx build ticket-api",
    "ticket-api:preview": "nx preview ticket-api",

    "events-api:serve": "nx serve events-api",
    "events-api:build": "nx build events-api",
    "events-api:preview": "nx preview events-api",

    "prisma-tickets:generate": "prisma generate --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:migrate-dev": "prisma migrate dev --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:migrate-reset": "prisma migrate reset --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:migrate-deploy": "prisma migrate deploy --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:studio": "prisma studio --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:db-push": "prisma db push --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:db-pull": "prisma db pull --config libs/databases/ticket-db/prisma.config.ts",
    "prisma-tickets:reset-and-generate": "npm run prisma-tickets:migrate-reset && npm run prisma-tickets:generate",
    "prisma-events:generate": "prisma generate --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:migrate-dev": "prisma migrate dev --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:migrate-deploy": "prisma migrate deploy --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:migrate-reset": "prisma migrate reset --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:studio": "prisma studio --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:db-push": "prisma db push --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:db-pull": "prisma db pull --config libs/databases/events-db/prisma.config.ts",
    "prisma-events:reset-and-generate": "npm run prisma-tickets:migrate-reset && npm run prisma-tickets:generate"
  },
  "private": true,
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.2",
    "@nx/eslint-plugin": "^22.7.1",
    "@nx/nest": "^22.7.1",
    "@nx/vue": "^22.7.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "ioredis": "^5.10.1",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.7.1",
    "@nx/js": "^22.7.1",
    "@nx/node": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.7.0",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/databases/*"
  ]
}
