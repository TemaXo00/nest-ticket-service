generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id String @id @default(uuid(4))

  name           String @unique
  tickets_amount Int    @default(1)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("event")
}
